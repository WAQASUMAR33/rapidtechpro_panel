// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  projects  Project[]

  @@map("categories")
}

model Technology {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  icon      String?
  projects  Project[]

  @@map("technologies")
}

model Project {
  id               Int     @id @default(autoincrement())
  title            String
  slug             String  @unique
  keyword          String
  metaTitle        String
  metaDescription  String
  canonicalTag     String?
  mainImage        String
  bannerImage      String?
  projectIcon      String? // Added field for project icon
  projectUrl       String
  videoUrl         String?
  location         String
  shortDescription String? @db.LongText
  blog             String? @db.LongText
  client           String?
  strategy         String? @db.LongText
  challenge        String? @db.LongText
  processSteps     String? @db.LongText
  features         String? @db.LongText
  results          String? @db.LongText
  successPoints    String? @db.LongText
  innovation       String? @db.LongText
  duration         String?
  categories       Category[]
  technologies     Technology[]
  images           ProjectImage[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("projects")
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageUrl  String
  createdAt DateTime @default(now())

  @@map("project_images")
}

model Service {
  id               Int      @id @default(autoincrement())
  title            String
  slug             String?   @unique
  description      String   @db.LongText

  icon             String?
  heroSubtitle     String?
  heroImage        String?
  coreOfferings    Json?
  platformExpertise Json?
  processSteps     Json?
  industries       Json?
  maintenance      String?  @db.LongText
  benefits         Json?
  techStack        Json?
  timeline         Json?
  testimonials     Json?
  caseStudies      Json?
  faq              Json?
  ctaTitle         String?
  ctaText          String?
  ctaButtonText    String?
  pricing          Pricing[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("services")
}

model Pricing {
  id            Int      @id @default(autoincrement())
  serviceId     Int
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Standard Tier
  standardName        String?  @default("Standard")
  standardPrice       Float?
  standardPriceSuffix String?  @default("Per Month")
  standardFeatures    Json?
  standardCta         String?  @default("Book Free Consultancy")
  standardIsPopular   Boolean  @default(false)

  // Premium Tier
  premiumName         String?  @default("Premium")
  premiumPrice        Float?
  premiumPriceSuffix  String?  @default("Per Month")
  premiumFeatures     Json?
  premiumCta          String?  @default("Book Free Consultancy")
  premiumIsPopular    Boolean  @default(false)

  // Custom Tier
  customName          String?  @default("Custom")
  customPrice         Float?
  customPriceSuffix   String?  @default("Per Month")
  customPriceLabel    String?  @default("Contact Us")
  customFeatures      Json?
  customCta           String?  @default("Book Free Consultancy")
  customIsPopular     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing")
}

model TeamMember {
  id           Int      @id @default(autoincrement())
  name         String
  designation  String
  role         String
  linkedinUrl  String?
  portfolioUrl String?
  image        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("team_members")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String
  review    String   @db.LongText
  ratings   Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}
